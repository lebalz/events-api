{
  "name": "events-api",
  "version": "1.0.1",
  "description": "School Events Planer API",
  "main": "src/server.ts",
  "author": "Balthasar Hofer",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npx prisma generate && tsc --build ./tsconfig.build.json && yarn copy-files && (yarn sentry:sourcemaps || true)",
    "copy-files": "cp -r docs dist/docs",
    "start": "node -r dotenv/config ./dist/src/server.js",
    "dev": "tsx --env-file=.env ./src/server.tsx",
    "bree:run": "tsx --env-file=.env ./src/bree-runner.tsx",
    "test:db:create": "npx prisma migrate dev",
    "test": "TZ=UTC jest -c jest.config.unit.js -- && TZ=UTC NODE_ENV=test jest -c jest.config.integration.js --",
    "unit": "TZ=UTC NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" NODE_ENV=test jest -c jest.config.unit.js --",
    "integration": "TZ=UTC NODE_ENV=test jest -c jest.config.integration.js",
    "cov": "TZ=UTC jest --collectCoverage -c jest.config.unit.js -- && TZ=UTC jest --collectCoverage -c jest.config.integration.js --",
    "cov:unit": "TZ=UTC jest --collectCoverage -c jest.config.unit.js --",
    "cov:integration": "TZ=UTC jest --collectCoverage -c jest.config.integration.js --",
    "db:cleanup": "tsx --env-file=.env ./bin/db_reset.ts",
    "db:reset": "yarn run db:cleanup && npx prisma migrate reset --force",
    "db:test": "PATH=\"$(yarn global bin):$PATH\" dotenv -e .test.env -- yarn prisma migrate deploy",
    "db:seed:users": "tsx --env-file=.env ./bin/users-csv-to-db.ts",
    "db:migrate-view": "tsx --env-file=.env ./prisma/view-migrations/create-view-migration.ts",
    "untis:fetch": "tsx --env-file=.env ./bin/fetch-untis.ts",
    "untis:sync": "tsx --env-file=.env ./bin/sync-untis-2-db.ts",
    "dummy:run": "tsx --env-file=.env ./bin/dummy.ts",
    "msft:fetch-users": "tsx --env-file=.env ./src/services/fetchUsers.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org balthasar-hofer --project node-express ./dist && sentry-cli sourcemaps upload --org $SENTRY_ORG --project $SENTRY_PROJECT ./dist"
  },
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@better-auth/sso": "^1.4.9",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@sentry/node": "^10.8.0",
    "better-auth": "^1.4.9",
    "bree": "^9.2.4",
    "compression": "^1.7.4",
    "connect-pg-simple": "^9.0.0",
    "cors": "^2.8.5",
    "cross-env": "^10.0.0",
    "csv-parse": "^5.5.3",
    "dotenv": "^17.2.2",
    "es-toolkit": "^1.43.0",
    "exceljs": "^4.3.0",
    "express": "^5.2.1",
    "global": "^4.4.0",
    "ics": "^3.1.0",
    "lodash": "^4.17.21",
    "mailgen": "^2.0.28",
    "microdiff": "^1.4.0",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "passport": "^0.7.0",
    "passport-azure-ad": "^4.3.4",
    "path": "^0.12.7",
    "pg": "^8.16.3",
    "read-excel-file": "^5.5.3",
    "socket.io": "^4.8.3",
    "uuid": "^10.0.0",
    "webuntis": "^2.2.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.0.2",
    "@sentry/cli": "^3.0.1",
    "@types/bree": "^7.1.0",
    "@types/compression": "^1.7.2",
    "@types/connect-pg-simple": "^7.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.14.197",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.7",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^6.4.15",
    "@types/passport-azure-ad": "^4.3.1",
    "@types/pg": "^8.16.0",
    "@types/safe-timers": "^1.1.2",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.6.4",
    "jest-mock-extended": "^3.0.7",
    "js-yaml": "^4.1.1",
    "minimist": "^1.2.8",
    "nodemon": "^3.1.10",
    "passport-mock-strategy": "^2.0.0",
    "prettier": "^3.6.2",
    "prisma": "^7.2.0",
    "prisma-dbml-generator": "^0.12.0",
    "prisma-docs-generator": "^0.8.0",
    "prisma-erd-generator": "^2.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.7",
    "utf-8-validate": "^6.0.3"
  },
  "engines": {
    "node": "^24.14.0"
  }
}
